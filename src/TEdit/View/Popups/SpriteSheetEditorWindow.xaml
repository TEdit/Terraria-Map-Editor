<ui:FluentWindow x:Class="TEdit.View.Popups.SpriteSheetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:TEdit.ViewModel"
        xmlns:p="clr-namespace:TEdit.Properties"
        Title="{Binding TileName, StringFormat={x:Static p:Language.spriteeditor_title_format}}"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ControlBackgroundBrush}"
        WindowBackdropType="Mica"
        Icon="/TEdit;component/Images/tedit.ico"
        Height="900" Width="1000"
        MinHeight="500" MinWidth="700"
        d:DataContext="{d:DesignInstance Type=vm:SpriteSheetEditorViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <!-- Checkerboard pattern for transparency indication -->
        <DrawingBrush x:Key="CheckerboardBrush" TileMode="Tile"
                      Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FF3A3A3A">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FF2A2A2A">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4"/>
                                <RectangleGeometry Rect="4,4,4,4"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </ui:FluentWindow.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar: tile info + texture-level actions -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <ui:Button Content="{x:Static p:Language.spriteeditor_zoom_out}" Command="{Binding ZoomOutCommand}" Padding="8,4" Margin="0,0,2,0"/>
                <ui:Button Content="{x:Static p:Language.spriteeditor_zoom_in}" Command="{Binding ZoomInCommand}" Padding="8,4" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ZoomLevel, StringFormat='{}{0:F1}x'}"
                           VerticalAlignment="Center" Margin="4,0,0,0" Foreground="Gray"/>
            </StackPanel>
            <TextBlock Text="{Binding TileName}" FontWeight="Bold" FontSize="14"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding TileId, StringFormat='(ID: {0})'}"
                       Foreground="Gray" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Texture canvas area (left side) — dark gray non-image background -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="#FF2D2D2D"
                ClipToBounds="True">
            <ScrollViewer x:Name="TextureScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="Transparent"
                          PreviewMouseWheel="TextureScrollViewer_PreviewMouseWheel">
                <Canvas x:Name="TextureCanvas"
                        MouseLeftButtonDown="TextureCanvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="TextureCanvas_MouseLeftButtonUp"
                        MouseMove="TextureCanvas_MouseMove"
                        MouseLeave="TextureCanvas_MouseLeave"
                        ClipToBounds="False"
                        Background="Transparent">
                    <Canvas.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                    </Canvas.LayoutTransform>
                    <!-- Checkerboard background for image area -->
                    <Rectangle x:Name="CheckerboardRect"
                               Fill="{StaticResource CheckerboardBrush}"
                               IsHitTestVisible="False"/>
                    <!-- Texture image -->
                    <Image x:Name="TextureImage"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Canvas.Left="0" Canvas.Top="0"/>
                    <!-- Image border -->
                    <Rectangle x:Name="ImageBorderRect"
                               Stroke="#FF888888"
                               Fill="Transparent"
                               IsHitTestVisible="False"/>
                    <!-- Selection rectangle for drag-select -->
                    <Rectangle x:Name="SelectionRect"
                               Stroke="#FF00BFFF"
                               Fill="#2000BFFF"
                               Visibility="Collapsed"
                               IsHitTestVisible="False"/>
                    <!-- Frame overlays drawn in code-behind -->
                </Canvas>
            </ScrollViewer>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="1" Grid.Column="1"
                      Width="6" Margin="4,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>

        <!-- Right panel: Grid settings + Frame properties -->
        <ScrollViewer Grid.Row="1" Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,14,0">
            <StackPanel Margin="4,0,0,0">

                <!-- Grid Settings -->
                <TextBox Text="{Binding TileName}" IsReadOnly="True" FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBlock Text="{x:Static p:Language.spriteeditor_grid_settings}" FontWeight="Bold" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_grid_w}" VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TextureGridX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static p:Language.spriteeditor_grid_h}" VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding TextureGridY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_gap_x}" VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FrameGapX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Static p:Language.spriteeditor_gap_y}" VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding FrameGapY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_size_w}" VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FrameSizeX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Static p:Language.spriteeditor_size_h}" VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding FrameSizeY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_row_heights}" VerticalAlignment="Center" Margin="0,0,4,4"
                               ToolTip="{x:Static p:Language.spriteeditor_row_heights_tooltip}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding CoordinateHeightsText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{x:Static p:Language.spriteeditor_row_heights_tooltip}"
                             Margin="0,0,0,4"/>

                    <CheckBox Grid.Row="4" Grid.ColumnSpan="4"
                              Content="{x:Static p:Language.spriteeditor_is_animated}"
                              IsChecked="{Binding IsAnimated}"
                              Margin="0,4,0,4"/>
                </Grid>

                <!-- Grid action buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button Content="{x:Static p:Language.spriteeditor_auto_detect}" Command="{Binding AutoDetectCommand}"
                               Padding="8,4" Margin="0,0,4,0"
                               ToolTip="{x:Static p:Language.spriteeditor_auto_detect_tooltip}"/>
                    <ui:Button Content="{x:Static p:Language.spriteeditor_regen_grid}" Click="RegenerateGrid_Click"
                               Padding="8,4" Margin="0,0,4,0"
                               ToolTip="{x:Static p:Language.spriteeditor_regen_grid_tooltip}"/>
                    <ui:Button Content="{x:Static p:Language.spriteeditor_single_frame}" Click="SingleFrame_Click"
                               Padding="8,4"
                               ToolTip="{x:Static p:Language.spriteeditor_single_frame_tooltip}"/>
                </StackPanel>

                <Separator Margin="0,0,0,8"/>

                <!-- Frame List -->
                <TextBlock FontWeight="Bold" Margin="0,0,0,4">
                    <Run Text="{x:Static p:Language.spriteeditor_frames}"/>
                    <Run Text="{Binding Frames.Count, Mode=OneWay, StringFormat='({0})'}" Foreground="Gray"/>
                </TextBlock>

                <ListBox x:Name="FrameListBox"
                         ItemsSource="{Binding Frames}"
                         SelectedItem="{Binding SelectedFrame, Mode=TwoWay}"
                         Height="160"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="X" FontSize="10" Padding="4,1"
                                        VerticalAlignment="Center" Margin="4,0,0,0"
                                        Click="RemoveFrame_Click"
                                        Tag="{Binding}"
                                        ToolTip="{x:Static p:Language.spriteeditor_remove_frame_tooltip}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                    <Run Text="{Binding UvX, Mode=OneWay, StringFormat='  UV({0},'}" Foreground="Gray"/>
                                    <Run Text="{Binding UvY, Mode=OneWay, StringFormat='{}{0})'}" Foreground="Gray"/>
                                </TextBlock>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Add Frame button below the list -->
                <ui:Button Content="{x:Static p:Language.spriteeditor_add_frame}" Command="{Binding AddFrameCommand}"
                           Padding="8,4" Margin="0,4,0,0"
                           HorizontalAlignment="Stretch"
                           ToolTip="{x:Static p:Language.spriteeditor_add_frame_tooltip}"/>

                <Separator Margin="0,8,0,8"/>

                <!-- Selected Frame Properties -->
                <TextBlock Text="{x:Static p:Language.spriteeditor_frame_properties}" FontWeight="Bold" Margin="0,0,0,8"/>

                <StackPanel Visibility="{Binding SelectedFrame, Converter={StaticResource NullToVisibilityConverter}}"
                            DataContext="{Binding SelectedFrame}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_name_label}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_variety_label}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Variety, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_uv_x}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding UvX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_uv_y}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding UvY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_size_w}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SizeX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_size_h}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SizeY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static p:Language.spriteeditor_anchor_label}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,4"
                                  SelectedValue="{Binding Anchor}"
                                  ItemsSource="{Binding Source={x:Static vm:SpriteSheetEditorViewModel.AnchorValues}}"/>
                    </Grid>
                </StackPanel>

                <!-- Hint shown when no frame selected (properties panel is collapsed) -->
                <TextBlock Text="{x:Static p:Language.spriteeditor_select_frame_hint}"
                           Foreground="Gray" FontStyle="Italic" Margin="0,4,0,0"
                           x:Name="NoFrameHint"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar: Status + Mouse coords + Add Selection + Save/Reset -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="Gray"/>
                <TextBlock x:Name="MouseCoordsText" VerticalAlignment="Center"
                           Foreground="Gray" Margin="16,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="AddSelectionButton" Content="{x:Static p:Language.spriteeditor_add_selection}"
                           Click="AddSelection_Click"
                           Padding="8,4" Margin="0,0,8,0"
                           Visibility="Collapsed"
                           ToolTip="{x:Static p:Language.spriteeditor_add_selection_tooltip}"/>
                <ui:Button Content="{x:Static p:Language.common_reset}" Command="{Binding ResetCommand}"
                           Padding="12,6" Margin="0,0,8,0"/>
                <ui:Button Content="{x:Static p:Language.common_save}" Command="{Binding SaveCommand}"
                           Padding="12,6" Margin="0,0,8,0" Appearance="Primary"/>
                <ui:Button Content="{x:Static p:Language.common_close}" Padding="12,6"
                           Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
