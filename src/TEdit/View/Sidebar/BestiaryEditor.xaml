<UserControl x:Class="TEdit.View.BestiaryEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:view="clr-namespace:TEdit.View"
        xmlns:viewModel="clr-namespace:TEdit.ViewModel"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:TEdit.Properties"
        xmlns:controls="clr-namespace:TEdit.UI.Controls"
        xmlns:converters="clr-namespace:TEdit.Converters"
        d:Width="360"
        d:Height="400"
        d:DataContext="{d:DesignInstance Type=viewModel:BestiaryViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NpcIdToPreviewConverter x:Key="NpcPreviewConverter" />
    </UserControl.Resources>
    <DockPanel Background="{DynamicResource SidebarBackgroundBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <!-- Title -->
        <TextBlock DockPanel.Dock="Top" Text="{x:Static p:Language.tool_bestiary_title}" Style="{DynamicResource SidebarPanelTitle}" />

        <!-- Toolbar -->
        <UniformGrid Columns="5" DockPanel.Dock="Top" Style="{DynamicResource SidebarButtonRow}">
            <ui:Button Content="{x:Static p:Language.bestiary_load}" Margin="2" Padding="6,4" HorizontalAlignment="Stretch" Command="{Binding LoadBestiaryCommand}" />
            <ui:Button Content="{x:Static p:Language.bestiary_clear}" Margin="2" Padding="6,4" HorizontalAlignment="Stretch" Command="{Binding ResetBestiaryCommand}" />
            <ui:Button Content="{x:Static p:Language.bestiary_complete}" Margin="2" Padding="6,4" HorizontalAlignment="Stretch" Command="{Binding CompleteBestiaryCommand}" />
            <ui:Button Content="{x:Static p:Language.bestiary_save}" Appearance="Success" Margin="2" Padding="6,4" HorizontalAlignment="Stretch" Command="{Binding SaveBestiaryCommand}" />
            <ui:Button Content="{x:Static p:Language.bestiary_tally}" Appearance="Danger" Margin="2" Padding="6,4" HorizontalAlignment="Stretch" Command="{Binding UpdateKillTallyCommand}" />
        </UniformGrid>

        <!-- Filter bar -->
        <Grid DockPanel.Dock="Top" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Static p:Language.banner_filter}" VerticalAlignment="Center" Margin="4,0" />
            <TextBox Grid.Column="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Margin="2" />
        </Grid>

        <ListView
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Name="BestiaryReadout"
            ItemsSource="{Binding BestiaryView}"
            GridViewColumnHeader.Click="GridViewColumnHeader_Click">
            <ListView.View>
                <GridView>

                    <!-- NPC preview icon -->
                    <GridViewColumn Width="36" Header="">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="24" Height="24" RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Source="{Binding NpcId, Converter={StaticResource NpcPreviewConverter}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Star rating (pentagon of stars) -->
                    <GridViewColumn Width="36" Header="⭐">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <controls:PentagonStarsControl Stars="{Binding BestiaryStars}" Width="24" Height="24" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="40" Header="ID" DisplayMemberBinding="{Binding NpcId}" />
                    <GridViewColumn Width="40" Header="BID" DisplayMemberBinding="{Binding BestiaryIndex}" />
                    <GridViewColumn Width="130" Header="{x:Static p:Language.bestiary_name}" DisplayMemberBinding="{Binding Name}" />

                    <GridViewColumn Header="{x:Static p:Language.bestiary_defeated}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Width="60" Text="{Binding Defeated}" Visibility="{Binding Path=CanKill, Converter={StaticResource BoolToVis}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{x:Static p:Language.bestiary_near}" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Near}" Visibility="{Binding Path=CanNear, Converter={StaticResource BoolToVis}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{x:Static p:Language.bestiary_chat}" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Talked}" Visibility="{Binding Path=CanTalk, Converter={StaticResource BoolToVis}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>


    </DockPanel>


</UserControl>
