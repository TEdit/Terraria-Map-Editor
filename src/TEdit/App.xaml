<Application x:Class="TEdit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- WPF UI theme resources (designer-safe) -->
        <ui:ThemesDictionary Theme="Dark" />
        <ui:ControlsDictionary />
        <!-- Custom overrides after WPF UI -->
        <ResourceDictionary Source="Themes\GlobalStyles.xaml" />
        <ResourceDictionary Source="Themes\Templates.xaml" />
        <ResourceDictionary Source="Themes\Icons.xaml" />
        <ResourceDictionary>
          <sys:Boolean x:Key="True">True</sys:Boolean>
          <sys:Boolean x:Key="False">False</sys:Boolean>

          <!-- ============================================= -->
          <!-- Muted text colors (VS Code dark style)        -->
          <!-- ============================================= -->
          <!-- WPF-UI default is #FFFFFF (pure white) -->
          <Color x:Key="TextFillColorPrimary">#CCCCCC</Color>
          <Color x:Key="TextFillColorSecondary">#9E9E9E</Color>
          <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#CCCCCC" />
          <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#9E9E9E" />

          <!-- Subtle fill for fluent list selection/hover (6% white) -->
          <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#0FFFFFFF" />

          <!-- ============================================= -->
          <!-- Compact UI Overrides for dense tool layout    -->
          <!-- ============================================= -->

          <!-- Global font size: WPF-UI default is 14 -->
          <sys:Double x:Key="ControlContentThemeFontSize">12</sys:Double>
          <sys:Double x:Key="ContentControlFontSize">12</sys:Double>

          <!-- Text input controls: default padding is 10,8,10,7 -->
          <Thickness x:Key="TextControlThemePadding">4,2,4,2</Thickness>
          <sys:Double x:Key="TextControlThemeMinHeight">24</sys:Double>
          <sys:Double x:Key="TextControlThemeMinWidth">0</sys:Double>

          <!-- Button: default padding is 11,5,11,6 -->
          <Thickness x:Key="ButtonPadding">6,2,6,2</Thickness>
          <Thickness x:Key="ButtonIconMargin">0,0,4,0</Thickness>

          <!-- ToggleButton: default padding is 11,5,11,5 -->
          <Thickness x:Key="ToggleButtonPadding">6,2,6,2</Thickness>
          <Thickness x:Key="ToggleButtonIconMargin">0,0,4,0</Thickness>

          <!-- ComboBox: default padding is 10,8,10,8 -->
          <Thickness x:Key="ComboBoxPadding">4,2,4,2</Thickness>
          <Thickness x:Key="ComboBoxItemContentMargin">4,1,4,1</Thickness>
          <Thickness x:Key="ComboBoxItemMargin">3,0,3,0</Thickness>
          <Thickness x:Key="ComboBoxChevronMargin">4,0,6,0</Thickness>
          <sys:Double x:Key="ComboBoxMinHeight">24</sys:Double>

          <!-- CheckBox: defaults Padding=11,5,11,6 Box=20x20 Icon=13 -->
          <Thickness x:Key="CheckBoxPadding">0</Thickness>
          <Thickness x:Key="CheckBoxContentMargin">4,0,0,0</Thickness>
          <sys:Double x:Key="CheckBoxHeight">16</sys:Double>
          <sys:Double x:Key="CheckBoxWidth">16</sys:Double>
          <sys:Double x:Key="CheckBoxIconSize">11</sys:Double>

          <!-- RadioButton -->
          <Thickness x:Key="RadioButtonContentMargin">4,0,0,0</Thickness>

          <!-- ListView / ListBox item density -->
          <sys:Double x:Key="ListViewItemMinHeight">24</sys:Double>

          <!-- TreeView -->
          <sys:Double x:Key="TreeViewItemMinHeight">20</sys:Double>

          <!-- Expander: default padding is 11,11,11,11 -->
          <Thickness x:Key="ExpanderPadding">6,4,6,4</Thickness>

          <!-- Card: default padding is 14,16,14,16 -->
          <Thickness x:Key="CardPadding">8,6,8,6</Thickness>

          <!-- InfoBar: default padding is 14,8,14,8 -->
          <Thickness x:Key="InfoBarPadding">8,4,8,4</Thickness>

          <!-- TextBox icon margins -->
          <Thickness x:Key="TextBoxLeftIconMargin">6,0,0,0</Thickness>
          <Thickness x:Key="TextBoxRightIconMargin">0,0,6,0</Thickness>
          <Thickness x:Key="TextBoxClearButtonMargin">0,0,2,0</Thickness>

          <!-- NumberBox -->
          <Thickness x:Key="NumberBoxLeftIconMargin">6,4,0,0</Thickness>
          <Thickness x:Key="NumberBoxRightIconMargin">0,4,6,0</Thickness>
          <Thickness x:Key="NumberBoxButtonMargin">0,2,2,0</Thickness>

          <!-- Corner radius: slightly tighter -->
          <CornerRadius x:Key="ControlCornerRadius">3,3,3,3</CornerRadius>

          <!-- DataGrid: default font 14 -->
          <sys:Double x:Key="DefaultDataGridFontSize">12</sys:Double>

          <!-- ============================================= -->

          <!-- Segoe Fluent Icons font for additional icons -->
          <FontFamily x:Key="SegoeFluentIcons">pack://application:,,,/TEdit;component/Fonts/#Segoe Fluent Icons</FontFamily>
        </ResourceDictionary>
      </ResourceDictionary.MergedDictionaries>

      <!-- Compact CheckBox: match ComboBox height (24) -->
      <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource DefaultCheckBoxStyle}">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="2,0" />
      </Style>

      <!-- Compact RadioButton: remove WPF-UI's large MinWidth/MinHeight -->
      <Style TargetType="{x:Type RadioButton}" BasedOn="{StaticResource DefaultRadioButtonStyle}">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="2,1,2,1" />
      </Style>

      <!-- ComboBox: always-visible scrollbar in dropdown (WPF-UI defaults to Hidden + opacity-faded) -->
      <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource DefaultComboBoxStyle}">
        <Setter Property="MaxDropDownHeight" Value="300" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
      </Style>

      <!-- Override WPF-UI DynamicScrollBar: thumb always visible (no opacity fade) -->
      <Style TargetType="{x:Type ui:DynamicScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="14" />
        <Setter Property="MinWidth" Value="14" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ui:DynamicScrollBar}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition MaxHeight="14" />
                  <RowDefinition Height="0.00001*" />
                  <RowDefinition MaxHeight="14" />
                </Grid.RowDefinitions>
                <Border x:Name="PART_Border" Grid.RowSpan="3" Width="12" HorizontalAlignment="Center"
                        Background="{DynamicResource ScrollBarTrackFillPointerOver}" CornerRadius="6" Opacity="0" />
                <RepeatButton x:Name="PART_ButtonScrollUp" Grid.Row="0" Command="ScrollBar.LineUpCommand"
                              Content="{x:Static ui:SymbolRegular.CaretUp24}" Opacity="0"
                              Style="{StaticResource DynamicScrollBarLineButton}" />
                <!-- Track has NO Opacity="0" — always visible -->
                <Track x:Name="PART_Track" Grid.Row="1" Width="6" IsDirectionReversed="True">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource DynamicScrollBarPageButton}" />
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Margin="0" Padding="0" Style="{StaticResource DynamicScrollBarThumb}" />
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource DynamicScrollBarPageButton}" />
                  </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton x:Name="PART_ButtonScrollDown" Grid.Row="2" Command="ScrollBar.LineDownCommand"
                              Content="{x:Static ui:SymbolRegular.CaretDown24}" Opacity="0"
                              Style="{StaticResource DynamicScrollBarLineButton}" />
              </Grid>
              <!-- Only animate decorative elements on hover; Track opacity stays at 1.0 always -->
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Trigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="PART_Track" Storyboard.TargetProperty="Width"
                                         From="6" To="8" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="PART_Border" Storyboard.TargetProperty="Opacity"
                                         From="0.0" To="1.0" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="PART_ButtonScrollUp" Storyboard.TargetProperty="Opacity"
                                         From="0.0" To="1.0" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="PART_ButtonScrollDown" Storyboard.TargetProperty="Opacity"
                                         From="0.0" To="1.0" Duration="0:0:0.16" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.EnterActions>
                  <Trigger.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="PART_Track" Storyboard.TargetProperty="Width"
                                         From="8" To="6" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="PART_Border" Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.0" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="PART_ButtonScrollUp" Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.0" Duration="0:0:0.16" />
                        <DoubleAnimation Storyboard.TargetName="PART_ButtonScrollDown" Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.0" Duration="0:0:0.16" />
                      </Storyboard>
                    </BeginStoryboard>
                  </Trigger.ExitActions>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <!-- Horizontal orientation override -->
          <Trigger Property="Orientation" Value="Horizontal">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="14" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ui:DynamicScrollBar}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition MaxWidth="14" />
                      <ColumnDefinition Width="0.00001*" />
                      <ColumnDefinition MaxWidth="14" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="PART_Border" Grid.ColumnSpan="3" Height="12" VerticalAlignment="Center"
                            Background="{DynamicResource ScrollBarTrackFillPointerOver}" CornerRadius="6" Opacity="0" />
                    <RepeatButton x:Name="PART_ButtonScrollLeft" Grid.Column="0" Command="ScrollBar.LineLeftCommand"
                                  Content="{x:Static ui:SymbolRegular.CaretLeft24}" Opacity="0"
                                  Style="{StaticResource DynamicScrollBarLineButton}" />
                    <Track x:Name="PART_Track" Grid.Column="1" Height="6" IsDirectionReversed="False" Orientation="Horizontal">
                      <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource DynamicScrollBarPageButton}" />
                      </Track.DecreaseRepeatButton>
                      <Track.Thumb>
                        <Thumb Margin="0" Padding="0" Style="{StaticResource DynamicScrollBarThumb}" />
                      </Track.Thumb>
                      <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource DynamicScrollBarPageButton}" />
                      </Track.IncreaseRepeatButton>
                    </Track>
                    <RepeatButton x:Name="PART_ButtonScrollRight" Grid.Column="2" Command="ScrollBar.LineRightCommand"
                                  Content="{x:Static ui:SymbolRegular.CaretRight24}" Opacity="0"
                                  Style="{StaticResource DynamicScrollBarLineButton}" />
                  </Grid>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Trigger.EnterActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="PART_Track" Storyboard.TargetProperty="Height"
                                             From="6" To="8" Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetName="PART_Border" Storyboard.TargetProperty="Opacity"
                                             From="0.0" To="1.0" Duration="0:0:0.16" />
                          </Storyboard>
                        </BeginStoryboard>
                      </Trigger.EnterActions>
                      <Trigger.ExitActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="PART_Track" Storyboard.TargetProperty="Height"
                                             From="8" To="6" Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetName="PART_Border" Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.0" Duration="0:0:0.16" />
                          </Storyboard>
                        </BeginStoryboard>
                      </Trigger.ExitActions>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Override WPF-UI DynamicScrollViewer: scrollbar beside content, not overlaid on top -->
      <Style TargetType="{x:Type ui:DynamicScrollViewer}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="PanningMode" Value="Both" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ui:DynamicScrollViewer}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Grid.Column="0" Padding="{TemplateBinding Padding}">
                  <ScrollContentPresenter CanContentScroll="{TemplateBinding CanContentScroll}" />
                </Border>
                <ui:DynamicScrollBar x:Name="PART_VerticalScrollBar" Grid.Row="0" Grid.Column="1"
                    IsScrolling="{TemplateBinding IsScrollingVertically}"
                    Maximum="{TemplateBinding ScrollableHeight}"
                    ViewportSize="{TemplateBinding ViewportHeight}"
                    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                    Value="{TemplateBinding VerticalOffset}" />
                <ui:DynamicScrollBar x:Name="PART_HorizontalScrollBar" Grid.Row="1" Grid.Column="0"
                    IsScrolling="{TemplateBinding IsScrollingHorizontally}"
                    Maximum="{TemplateBinding ScrollableWidth}"
                    Orientation="Horizontal"
                    ViewportSize="{TemplateBinding ViewportWidth}"
                    Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                    Value="{TemplateBinding HorizontalOffset}" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Compact icon-only button: minimal padding for tight layouts (e.g. chest editor) -->
      <Style x:Key="CompactIconButton" TargetType="{x:Type Button}" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Padding" Value="2"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
      </Style>


    </ResourceDictionary>
  </Application.Resources>
</Application>
